<!-- 冥想播放页 -->
<view class="session-page" wx:if="{{scene}}">

  <!-- 场景背景图（模糊） -->
  <image class="scene-bg" src="{{scene.bgImage}}" mode="aspectFill"></image>
  <view class="scene-bg-overlay" style="background: linear-gradient(160deg, {{scene.bgGradient[0]}}cc 0%, {{scene.bgGradient[1]}}dd 60%, {{scene.bgGradient[1]}} 100%)"></view>

  <!-- 场景粒子效果 -->
  <!-- 雨滴效果 -->
  <view class="effect-layer" wx:if="{{scene.effect === 'rain'}}">
    <view class="raindrop" style="left:10%;animation-delay:0s;animation-duration:0.8s"></view>
    <view class="raindrop" style="left:18%;animation-delay:0.3s;animation-duration:1.1s"></view>
    <view class="raindrop" style="left:25%;animation-delay:0.7s;animation-duration:0.9s"></view>
    <view class="raindrop" style="left:33%;animation-delay:0.1s;animation-duration:1.3s"></view>
    <view class="raindrop" style="left:40%;animation-delay:0.5s;animation-duration:0.7s"></view>
    <view class="raindrop" style="left:48%;animation-delay:0.2s;animation-duration:1.0s"></view>
    <view class="raindrop" style="left:55%;animation-delay:0.8s;animation-duration:0.85s"></view>
    <view class="raindrop" style="left:62%;animation-delay:0.4s;animation-duration:1.2s"></view>
    <view class="raindrop" style="left:70%;animation-delay:0.6s;animation-duration:0.75s"></view>
    <view class="raindrop" style="left:78%;animation-delay:0.15s;animation-duration:1.05s"></view>
    <view class="raindrop" style="left:85%;animation-delay:0.55s;animation-duration:0.95s"></view>
    <view class="raindrop" style="left:92%;animation-delay:0.35s;animation-duration:1.15s"></view>
  </view>

  <!-- 海浪效果 -->
  <view class="effect-layer" wx:if="{{scene.effect === 'wave'}}">
    <view class="wave-line wave-line-1"></view>
    <view class="wave-line wave-line-2"></view>
    <view class="wave-line wave-line-3"></view>
  </view>

  <!-- 阳光效果 -->
  <view class="effect-layer" wx:if="{{scene.effect === 'sunbeam'}}">
    <view class="sunbeam sunbeam-1"></view>
    <view class="sunbeam sunbeam-2"></view>
    <view class="sunbeam sunbeam-3"></view>
    <view class="sunbeam sunbeam-4"></view>
    <view class="sunbeam sunbeam-5"></view>
  </view>

  <!-- 星星效果 -->
  <view class="effect-layer" wx:if="{{scene.effect === 'star'}}">
    <view class="star-particle" style="left:12%;top:8%;animation-delay:0s"></view>
    <view class="star-particle" style="left:28%;top:15%;animation-delay:1.2s"></view>
    <view class="star-particle" style="left:45%;top:5%;animation-delay:0.5s"></view>
    <view class="star-particle" style="left:62%;top:18%;animation-delay:2.0s"></view>
    <view class="star-particle" style="left:78%;top:10%;animation-delay:0.8s"></view>
    <view class="star-particle" style="left:88%;top:22%;animation-delay:1.5s"></view>
    <view class="star-particle" style="left:20%;top:25%;animation-delay:2.5s"></view>
    <view class="star-particle" style="left:55%;top:28%;animation-delay:1.8s"></view>
    <view class="star-particle" style="left:70%;top:6%;animation-delay:0.3s"></view>
    <view class="star-particle" style="left:35%;top:20%;animation-delay:3.0s"></view>
  </view>

  <!-- 气泡效果 -->
  <view class="effect-layer" wx:if="{{scene.effect === 'bubble'}}">
    <view class="bubble" style="left:15%;animation-delay:0s;animation-duration:4s;width:16rpx;height:16rpx"></view>
    <view class="bubble" style="left:30%;animation-delay:1.5s;animation-duration:5s;width:24rpx;height:24rpx"></view>
    <view class="bubble" style="left:50%;animation-delay:0.5s;animation-duration:4.5s;width:20rpx;height:20rpx"></view>
    <view class="bubble" style="left:65%;animation-delay:2s;animation-duration:5.5s;width:14rpx;height:14rpx"></view>
    <view class="bubble" style="left:80%;animation-delay:1s;animation-duration:4.2s;width:22rpx;height:22rpx"></view>
    <view class="bubble" style="left:40%;animation-delay:3s;animation-duration:6s;width:18rpx;height:18rpx"></view>
  </view>

  <!-- 莲花花瓣效果 -->
  <view class="effect-layer" wx:if="{{scene.effect === 'lotus'}}">
    <view class="lotus-petal lotus-petal-1"></view>
    <view class="lotus-petal lotus-petal-2"></view>
    <view class="lotus-petal lotus-petal-3"></view>
    <view class="lotus-petal lotus-petal-4"></view>
  </view>

  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="confirmExit">
      <text class="nav-back-icon">✕</text>
    </view>
    <text class="nav-title">{{scene.name}}</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 冥想进行中 -->
  <view class="session-content">

    <!-- 呼吸动画圆 -->
    <view class="breath-area">
      <view class="breath-ring breath-ring--outer {{breathPhase}}">
        <view class="breath-ring breath-ring--middle">
          <view class="breath-ring breath-ring--inner">
            <text class="breath-icon">{{scene.icon}}</text>
          </view>
        </view>
      </view>
      <text class="breath-label">{{breathLabel}}</text>
      <text class="breath-hint">{{breathHint}}</text>
    </view>

    <!-- 引导文案 -->
    <view class="guide-box" wx:if="{{showGuide}}">
      <text class="guide-text">{{currentGuide}}</text>
    </view>

    <!-- 计时器 -->
    <view class="timer-area">
      <text class="timer-display">{{timerMinutes < 10 ? '0' : ''}}{{timerMinutes}}:{{timerSeconds < 10 ? '0' : ''}}{{timerSeconds}}</text>
      <text class="timer-label">剩余时间</text>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progress * 100}}%"></view>
      </view>
    </view>

    <!-- 控制按钮 -->
    <view class="controls">
      <view class="ctrl-btn ctrl-sm" bindtap="toggleGuide">
        <text class="ctrl-icon">{{showGuide ? '✦' : '◇'}}</text>
      </view>
      <!-- 中间按钮：播放中点击暂停，暂停中点击恢复，暂停中长按3秒结束 -->
      <view
        class="ctrl-btn ctrl-lg {{isPlaying ? 'ctrl-playing' : ''}} {{longPressing ? 'ctrl-longpress' : ''}}"
        catchtouchstart="onPlayBtnTouchStart"
        catchtouchend="onPlayBtnTouchEnd"
        catchtouchmove="onPlayBtnTouchMove"
        catchtouchcancel="onPlayBtnTouchCancel"
      >
        <view class="long-press-ring" wx:if="{{longPressing && !isPlaying}}">
          <view class="long-press-progress" style="animation: longPressAnim 3s linear forwards;"></view>
        </view>
        <text class="ctrl-play">{{isPlaying ? '❚❚' : (longPressing ? longPressSec : '▶')}}</text>
      </view>
      <view class="ctrl-btn ctrl-sm" bindtap="toggleSound">
        <text class="ctrl-icon" style="opacity: {{soundOn ? 1 : 0.3}}">♪</text>
      </view>
    </view>

    <!-- 暂停时提示 -->
    <view wx:if="{{!isPlaying && !longPressing}}" class="pause-hint">
      <text class="pause-hint-text">长按 ▶ 按钮 3 秒结束冥想</text>
    </view>
    <view wx:if="{{longPressing && !isPlaying}}" class="pause-hint">
      <text class="pause-hint-text pause-hint-counting">松手取消 · 继续{{longPressSec < 3 ? (3 - longPressSec) : ''}}</text>
    </view>

  </view>

  <!-- 提前结束提示 -->
  <view class="end-toast-mask" wx:if="{{showEndToast}}">
    <view class="end-toast-card">
      <text class="end-toast-emoji">🧘</text>
      <text class="end-toast-title">本次冥想 {{actualMeditated}} 分钟</text>
      <text class="end-toast-sub">继续加油，下次再来</text>
    </view>
  </view>

  <!-- 完成弹窗 -->
  <view class="modal-mask" wx:if="{{showComplete}}">
    <view class="modal-card">
      <text class="modal-emoji">🧘</text>
      <text class="modal-title">冥想完成</text>
      <text class="modal-sub">你已完成 {{duration}} 分钟的{{scene.name}}</text>
      <view class="modal-stats">
        <view class="ms-item">
          <text class="ms-num">{{duration}}</text>
          <text class="ms-label">分钟</text>
        </view>
        <view class="ms-div"></view>
        <view class="ms-item">
          <text class="ms-num">{{totalToday}}</text>
          <text class="ms-label">今日总计</text>
        </view>
        <view class="ms-div"></view>
        <view class="ms-item">
          <text class="ms-num">{{newStreak}}</text>
          <text class="ms-label">连续天数</text>
        </view>
      </view>
      <button class="btn-primary modal-btn" bindtap="finish">返回首页</button>
      <text class="modal-again" bindtap="doAgain">再来一次</text>
    </view>
  </view>
</view>
