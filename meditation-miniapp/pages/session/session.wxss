/* 冥想播放页样式 - 春日清新风 + 场景背景 */
.session-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
  background: #F7F4EE;
}

/* ============ 场景背景图（模糊） ============ */
.scene-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  filter: blur(30px);
  transform: scale(1.15);
  z-index: 0;
  pointer-events: none;
}
.scene-bg-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  pointer-events: none;
}

/* ============ 粒子效果层 ============ */
.effect-layer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  pointer-events: none;
  overflow: hidden;
}

/* --- 雨滴效果 --- */
.raindrop {
  position: absolute;
  top: -20rpx;
  width: 2rpx;
  height: 40rpx;
  background: linear-gradient(to bottom, transparent, rgba(107,155,125,0.35));
  border-radius: 0 0 2rpx 2rpx;
  animation: rainFall linear infinite;
}
@keyframes rainFall {
  0% { transform: translateY(0); opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { transform: translateY(140vh); opacity: 0; }
}

/* --- 海浪效果 --- */
.wave-line {
  position: absolute;
  bottom: -20rpx;
  left: -20%;
  width: 140%;
  height: 200rpx;
  border-radius: 50% 50% 0 0;
  opacity: 0.15;
}
.wave-line-1 {
  background: rgba(74,144,184,0.3);
  animation: waveMove1 6s ease-in-out infinite;
}
.wave-line-2 {
  background: rgba(74,144,184,0.2);
  bottom: -50rpx;
  animation: waveMove2 8s ease-in-out infinite;
}
.wave-line-3 {
  background: rgba(74,144,184,0.15);
  bottom: -80rpx;
  animation: waveMove3 10s ease-in-out infinite;
}
@keyframes waveMove1 {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(60rpx); }
}
@keyframes waveMove2 {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(-80rpx); }
}
@keyframes waveMove3 {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(40rpx); }
}

/* --- 阳光效果 --- */
.sunbeam {
  position: absolute;
  top: -40rpx;
  width: 4rpx;
  height: 60vh;
  background: linear-gradient(to bottom, rgba(212,148,58,0.2), transparent);
  transform-origin: top center;
  animation: sunbeamPulse 4s ease-in-out infinite;
}
.sunbeam-1 { left: 15%; transform: rotate(15deg); animation-delay: 0s; }
.sunbeam-2 { left: 30%; transform: rotate(8deg); animation-delay: 0.8s; width: 6rpx; }
.sunbeam-3 { left: 50%; transform: rotate(-5deg); animation-delay: 1.6s; }
.sunbeam-4 { left: 68%; transform: rotate(-12deg); animation-delay: 2.4s; width: 3rpx; }
.sunbeam-5 { left: 82%; transform: rotate(-20deg); animation-delay: 3.2s; width: 5rpx; }
@keyframes sunbeamPulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.7; }
}

/* --- 星星效果 --- */
.star-particle {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255,255,255,0.8);
  border-radius: 50%;
  box-shadow: 0 0 12rpx rgba(255,255,255,0.5);
  animation: starTwinkle 3s ease-in-out infinite;
}
@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.3); }
}

/* --- 气泡效果 --- */
.bubble {
  position: absolute;
  bottom: -40rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(199,107,90,0.3);
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.15), transparent);
  animation: bubbleRise ease-in infinite;
}
@keyframes bubbleRise {
  0% { transform: translateY(0) translateX(0); opacity: 0; }
  10% { opacity: 0.8; }
  90% { opacity: 0.6; }
  100% { transform: translateY(-130vh) translateX(40rpx); opacity: 0; }
}

/* --- 莲花花瓣效果 --- */
.lotus-petal {
  position: absolute;
  bottom: 100rpx;
  width: 60rpx;
  height: 120rpx;
  border-radius: 50% 50% 0 0;
  background: rgba(139,123,94,0.06);
  transform-origin: bottom center;
  animation: lotusFloat 8s ease-in-out infinite;
}
.lotus-petal-1 { left: 20%; transform: rotate(-20deg); animation-delay: 0s; }
.lotus-petal-2 { left: 40%; transform: rotate(-8deg); animation-delay: 2s; }
.lotus-petal-3 { right: 40%; transform: rotate(8deg); animation-delay: 4s; }
.lotus-petal-4 { right: 20%; transform: rotate(20deg); animation-delay: 6s; }
@keyframes lotusFloat {
  0%, 100% { transform: rotate(var(--rot, 0deg)) translateY(0); opacity: 0.4; }
  50% { transform: rotate(var(--rot, 0deg)) translateY(-30rpx); opacity: 0.7; }
}

/* ============ 冥想内容区 ============ */
.session-content {
  width: 100%;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  position: relative;
  z-index: 10;
  padding-top: 140rpx;
}

/* 导航栏 */
.nav-bar {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 88rpx 44rpx 12rpx;
  box-sizing: border-box;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 50;
}
.nav-back {
  width: 68rpx;
  height: 68rpx;
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(10px);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}
.nav-back-icon { font-size: 24rpx; color: #3D3529; }
.nav-title {
  font-size: 28rpx;
  color: #3D3529;
  letter-spacing: 6rpx;
  font-weight: 500;
}
.nav-placeholder { width: 68rpx; }

/* 呼吸动画区 */
.breath-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 20rpx;
  flex-shrink: 0;
}

.breath-ring {
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.breath-ring--outer {
  width: 360rpx;
  height: 360rpx;
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(8px);
  border: 1rpx solid rgba(255,255,255,0.4);
  transition: transform 4s ease-in-out, background 4s ease-in-out;
}

.breath-ring--middle {
  width: 268rpx;
  height: 268rpx;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(6px);
  border: 1rpx solid rgba(255,255,255,0.35);
}

.breath-ring--inner {
  width: 168rpx;
  height: 168rpx;
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(4px);
  border: 1rpx solid rgba(255,255,255,0.4);
}

/* 呼吸动画状态 */
.breath-ring--outer.inhale {
  transform: scale(1.18);
  background: rgba(255,255,255,0.35);
  box-shadow: 0 0 40rpx rgba(107, 155, 125, 0.15);
}
.breath-ring--outer.hold {
  transform: scale(1.18);
  background: rgba(255,255,255,0.3);
}
.breath-ring--outer.exhale {
  transform: scale(0.88);
  background: rgba(255,255,255,0.15);
}

.breath-icon { font-size: 72rpx; }
.breath-label {
  font-size: 32rpx;
  color: #5A5040;
  letter-spacing: 10rpx;
  margin-top: 80rpx;
  font-weight: 300;
}
.breath-hint {
  font-size: 22rpx;
  color: #B0A898;
  margin-top: 16rpx;
  letter-spacing: 3rpx;
}

/* 引导文案 */
.guide-box {
  margin: 20rpx 52rpx;
  padding: 28rpx 36rpx;
  background: rgba(255,255,255,0.55);
  backdrop-filter: blur(10px);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
  box-shadow: 0 2rpx 12rpx rgba(61, 53, 41, 0.04);
}
.guide-text {
  font-size: 26rpx;
  color: #5A5040;
  line-height: 1.8;
  letter-spacing: 2rpx;
  display: block;
  text-align: center;
  font-weight: 300;
}

/* 计时器 */
.timer-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 80rpx;
  width: 100%;
  box-sizing: border-box;
  margin-top: 48rpx;
  margin-bottom: 0;
}
.timer-display {
  font-size: 96rpx;
  font-weight: 200;
  color: #3D3529;
  letter-spacing: 10rpx;
  font-variant-numeric: tabular-nums;
}
.timer-label {
  font-size: 20rpx;
  color: #B0A898;
  margin-top: 4rpx;
  letter-spacing: 4rpx;
}

.progress-bar {
  width: 100%;
  height: 2rpx;
  background: rgba(61, 53, 41, 0.08);
  border-radius: 100rpx;
  margin-top: 20rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, rgba(107,155,125,0.4), rgba(107,155,125,0.8));
  border-radius: 100rpx;
  transition: width 1s linear;
}

/* 控制按钮 */
.controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 56rpx;
  margin-top: 64rpx;
  padding-bottom: 16rpx;
}
.ctrl-btn {
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}
.ctrl-sm {
  width: 88rpx;
  height: 88rpx;
  background: rgba(255,255,255,0.5);
  backdrop-filter: blur(8px);
  border: 1rpx solid rgba(255,255,255,0.4);
}
.ctrl-lg {
  width: 132rpx;
  height: 132rpx;
  background: rgba(255,255,255,0.4);
  backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 4rpx 20rpx rgba(107, 155, 125, 0.12);
}
.ctrl-lg.ctrl-playing {
  background: rgba(255,255,255,0.5);
  border-color: rgba(255,255,255,0.6);
  box-shadow: 0 4rpx 24rpx rgba(107, 155, 125, 0.2);
}
.ctrl-lg.ctrl-longpress {
  border-color: rgba(199, 107, 90, 0.5);
  background: rgba(199, 107, 90, 0.08);
}
.ctrl-icon { font-size: 30rpx; color: #7A7060; }
.ctrl-play {
  font-size: 40rpx;
  color: #4E7F62;
  position: relative;
  z-index: 2;
}

/* 按钮内进度环（长按时） */
.long-press-ring {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  overflow: hidden;
  z-index: 1;
}
.long-press-progress {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  width: 0;
  background: rgba(199, 107, 90, 0.15);
  border-radius: 50%;
}

@keyframes longPressAnim {
  from { width: 0; }
  to { width: 100%; }
}

/* 暂停提示 */
.pause-hint {
  padding: 8rpx 0 32rpx;
  text-align: center;
}
.pause-hint-text {
  font-size: 20rpx;
  color: #B0A898;
  letter-spacing: 3rpx;
  font-weight: 300;
}
.pause-hint-counting {
  color: rgba(199, 107, 90, 0.7);
}

/* 完成弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(61, 53, 41, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.modal-card {
  background: #FFFFFF;
  border-radius: 36rpx;
  padding: 60rpx 48rpx;
  width: 580rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid #E4DFD6;
  box-shadow: 0 16rpx 48rpx rgba(61, 53, 41, 0.12);
}
.modal-emoji { font-size: 80rpx; }
.modal-title {
  font-size: 40rpx;
  color: #3D3529;
  font-weight: 300;
  letter-spacing: 8rpx;
  margin: 20rpx 0 8rpx;
}
.modal-sub {
  font-size: 22rpx;
  color: #9A9080;
  letter-spacing: 2rpx;
  margin-bottom: 40rpx;
}
.modal-stats {
  display: flex;
  width: 100%;
  background: #F7F4EE;
  border-radius: 20rpx;
  padding: 28rpx 0;
  margin-bottom: 40rpx;
  border: 1rpx solid #E4DFD6;
}
.ms-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.ms-num { font-size: 44rpx; color: #6B9B7D; font-weight: 300; }
.ms-label { font-size: 20rpx; color: #9A9080; margin-top: 6rpx; }
.ms-div { width: 1rpx; background: #E4DFD6; }

.modal-btn { width: 100%; height: 92rpx; font-size: 28rpx; letter-spacing: 6rpx; }
.modal-again {
  font-size: 24rpx;
  color: #9A9080;
  margin-top: 24rpx;
  letter-spacing: 2rpx;
}

/* 提前结束提示弹窗 */
.end-toast-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(61, 53, 41, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 110;
}
.end-toast-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 52rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid #E4DFD6;
  animation: fadeInUp 0.3s ease;
  box-shadow: 0 12rpx 40rpx rgba(61, 53, 41, 0.1);
}
.end-toast-emoji { font-size: 64rpx; }
.end-toast-title {
  font-size: 36rpx;
  color: #3D3529;
  font-weight: 300;
  letter-spacing: 5rpx;
  margin-top: 20rpx;
}
.end-toast-sub {
  font-size: 22rpx;
  color: #9A9080;
  letter-spacing: 2rpx;
  margin-top: 10rpx;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}
