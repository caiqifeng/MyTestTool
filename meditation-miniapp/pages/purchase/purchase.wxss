/* 购买页面样式 - 春日清新 */
.purchase-page {
  min-height: 100vh;
  background: #F7F4EE;
  padding: 0 32rpx 60rpx;
}

/* 顶部用户信息 */
.purchase-header {
  padding: 40rpx 0 32rpx;
}

.purchase-user-row {
  display: flex;
  align-items: center;
}

.purchase-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #E4DFD6;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.purchase-user-info {
  display: flex;
  flex-direction: column;
}

.purchase-username {
  font-size: 32rpx;
  color: #3D3529;
  font-weight: 500;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.purchase-vip-tag {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #F5E6C8 0%, #E8D4A8 100%);
  border-radius: 100rpx;
  padding: 4rpx 16rpx;
  border: 1rpx solid rgba(200, 170, 120, 0.3);
}

.purchase-vip-tag--on {
  background: linear-gradient(135deg, #6B9B7D 0%, #4E7F62 100%);
  border-color: rgba(107, 155, 125, 0.4);
}

.purchase-vip-tag-icon { font-size: 20rpx; }
.purchase-vip-tag-text {
  font-size: 20rpx;
  color: #8B7355;
  margin-left: 6rpx;
}

.purchase-vip-tag--on .purchase-vip-tag-text {
  color: rgba(255, 255, 255, 0.95);
}

/* 区块标签 */
.section-label {
  display: block;
  font-size: 24rpx;
  color: #9A9080;
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
}

/* 场景购买卡片 */
.scene-section { margin-bottom: 20rpx; }

.scene-buy-card {
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(61, 53, 41, 0.08);
}

.scene-buy-icon { font-size: 56rpx; margin-right: 20rpx; flex-shrink: 0; }

.scene-buy-info { flex: 1; }
.scene-buy-name {
  display: block;
  font-size: 30rpx;
  color: #3D3529;
  font-weight: 400;
  letter-spacing: 2rpx;
  margin-bottom: 4rpx;
}
.scene-buy-desc {
  display: block;
  font-size: 20rpx;
  color: #7A7060;
  letter-spacing: 1rpx;
}

.scene-buy-price {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.scene-buy-price-num {
  font-size: 36rpx;
  color: #6B9B7D;
  font-weight: 500;
}

.btn-buy-scene {
  width: 100%;
  height: 96rpx;
  background: #FFFFFF;
  color: #6B9B7D;
  border-radius: 20rpx;
  font-size: 28rpx;
  letter-spacing: 4rpx;
  border: 2rpx solid rgba(107, 155, 125, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(107, 155, 125, 0.1);
}

.btn-buy-scene::after { border: none; }

/* 分割线 */
.purchase-divider {
  display: flex;
  align-items: center;
  margin: 28rpx 0 32rpx;
}

.purchase-divider-line { flex: 1; height: 1rpx; background: #E4DFD6; }

.purchase-divider-text {
  font-size: 20rpx;
  color: #B0A898;
  padding: 0 20rpx;
  white-space: nowrap;
}

/* VIP方案 */
.vip-section { margin-bottom: 32rpx; }

.vip-cards {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.vip-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid #E4DFD6;
  position: relative;
  transition: all 0.2s ease;
}

.vip-card:active { transform: scale(0.97); }

.vip-card--active {
  border-color: #6B9B7D;
  box-shadow: 0 0 0 2rpx rgba(107, 155, 125, 0.2);
}

.vip-card--hot {
  background: linear-gradient(160deg, #F0F7F2 0%, #E4F0E8 100%);
  border-color: rgba(107, 155, 125, 0.3);
}

.vip-card-badge {
  position: absolute;
  top: -1rpx;
  right: -1rpx;
  background: linear-gradient(135deg, #6B9B7D 0%, #4E7F62 100%);
  color: white;
  font-size: 18rpx;
  padding: 6rpx 16rpx;
  border-radius: 0 20rpx 0 16rpx;
  letter-spacing: 1rpx;
}

.vip-card-name {
  font-size: 24rpx;
  color: #3D3529;
  font-weight: 400;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.vip-card-price {
  font-size: 52rpx;
  color: #6B9B7D;
  font-weight: 300;
  line-height: 1;
}

.vip-card-period {
  font-size: 20rpx;
  color: #9A9080;
  margin-bottom: 8rpx;
}

.vip-card-desc {
  font-size: 20rpx;
  color: #B0A898;
  letter-spacing: 1rpx;
}

.btn-buy-vip {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #6B9B7D 0%, #4E7F62 100%);
  color: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  font-size: 30rpx;
  letter-spacing: 6rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(107, 155, 125, 0.35);
}

.btn-buy-vip::after { border: none; }

/* 会员权益 */
.benefits-section { margin-bottom: 40rpx; }

.benefit-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 12rpx 28rpx;
  border: 1rpx solid rgba(61, 53, 41, 0.04);
  box-shadow: 0 2rpx 12rpx rgba(61, 53, 41, 0.04);
}

.benefit-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
}

.benefit-icon { font-size: 32rpx; margin-right: 16rpx; }
.benefit-text {
  font-size: 26rpx;
  color: #3D3529;
  letter-spacing: 1rpx;
}
