/* 登录页面样式 - 春日清新 */
.login-page {
  min-height: 100vh;
  background: #F7F4EE;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}

/* 顶部 */
.login-top {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0 80rpx;
}

.login-logo {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.login-title {
  font-size: 44rpx;
  color: #3D3529;
  font-weight: 300;
  letter-spacing: 8rpx;
  margin-bottom: 12rpx;
}

.login-sub {
  font-size: 24rpx;
  color: #9A9080;
  letter-spacing: 2rpx;
}

/* 登录卡片 */
.login-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(61, 53, 41, 0.06);
  border: 1rpx solid rgba(61, 53, 41, 0.04);
}

.login-card-title {
  display: block;
  font-size: 26rpx;
  color: #9A9080;
  letter-spacing: 4rpx;
  text-align: center;
  margin-bottom: 40rpx;
}

/* 微信登录按钮 */
.btn-wechat {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #6B9B7D 0%, #4E7F62 100%);
  border-radius: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 0;
  box-shadow: 0 8rpx 24rpx rgba(107, 155, 125, 0.35);
  letter-spacing: 4rpx;
}

.btn-wechat::after { border: none; }

.btn-wechat-icon { font-size: 32rpx; margin-right: 10rpx; }
.btn-wechat-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 4rpx;
  font-weight: 400;
}

/* 游客体验 */
.guest-row {
  padding: 32rpx 0 8rpx;
  text-align: center;
}

.guest-text {
  font-size: 24rpx;
  color: #B0A898;
  letter-spacing: 1rpx;
}

.guest-row:active .guest-text {
  color: #9A9080;
}

/* 协议 */
.agreement {
  margin-top: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
}

.agreement-text {
  font-size: 20rpx;
  color: #B0A898;
}

.agreement-link {
  font-size: 20rpx;
  color: #6B9B7D;
}
