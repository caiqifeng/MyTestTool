/* 我的页面样式 - 春日清新 */
.profile-page { padding: 0 28rpx 200rpx; }

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 36rpx;
}

.avatar-ring {
  width: 172rpx;
  height: 172rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(107,155,125,0.2), rgba(139,184,157,0.1));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.avatar-box {
  width: 152rpx;
  height: 152rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(107,155,125,0.2);
  box-shadow: 0 4rpx 16rpx rgba(107,155,125,0.1);
}

.avatar-emoji { font-size: 72rpx; }

.avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
}

.avatar-emoji--guest { font-size: 64rpx; }

/* 登录按钮 */
.btn-login {
  margin-top: 28rpx;
  padding: 20rpx 64rpx;
  background: linear-gradient(135deg, #6B9B7D 0%, #4E7F62 100%);
  color: rgba(255, 255, 255, 0.95);
  border-radius: 100rpx;
  font-size: 26rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 20rpx rgba(107, 155, 125, 0.3);
}

.username {
  font-size: 36rpx;
  color: #3D3529;
  font-weight: 500;
  letter-spacing: 4rpx;
}

/* VIP状态徽章 */
.vip-status-badge {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #F5E6C8 0%, #E8D4A8 100%);
  border-radius: 100rpx;
  padding: 8rpx 24rpx;
  margin-top: 12rpx;
  border: 1rpx solid rgba(200, 170, 120, 0.3);
}

.vip-status--on {
  background: linear-gradient(135deg, #6B9B7D 0%, #4E7F62 100%);
  border-color: rgba(107, 155, 125, 0.4);
}

.vip-status-icon { font-size: 22rpx; }
.vip-status-text {
  font-size: 20rpx;
  color: #8B7355;
  margin-left: 8rpx;
  letter-spacing: 1rpx;
}

.vip-status--on .vip-status-text {
  color: rgba(255, 255, 255, 0.95);
}

.user-sub { font-size: 22rpx; color: #9A9080; margin-top: 6rpx; }

.user-stats-row {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  background: #FFFFFF;
  border-radius: 100rpx;
  padding: 16rpx 32rpx;
  border: 1rpx solid rgba(107,155,125,0.15);
  box-shadow: 0 2rpx 12rpx rgba(107,155,125,0.06);
}
.user-stat { display: flex; align-items: baseline; }
.user-stat-num { font-size: 28rpx; color: #6B9B7D; font-weight: 500; margin-right: 4rpx; }
.user-stat-label { font-size: 18rpx; color: #9A9080; }
.user-stat-dot { width: 6rpx; height: 6rpx; border-radius: 50%; background: #D4C8B8; margin: 0 16rpx; }

/* 区块标题 */
.block-title { padding: 28rpx 0 14rpx; }
.block-title-text { font-size: 24rpx; color: #9A9080; letter-spacing: 4rpx; }

/* 成就 - 一行2个 */
.ach-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.ach-card {
  width: calc(50% - 8rpx);
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(107,155,125,0.1);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
  opacity: 0.35;
  transition: all 0.3s;
  box-sizing: border-box;
}
.ach-card--on {
  opacity: 1;
  border-color: rgba(107,155,125,0.3);
  background: linear-gradient(135deg, rgba(107,155,125,0.06), rgba(139,184,157,0.04));
  box-shadow: 0 4rpx 16rpx rgba(107,155,125,0.08);
}
.ach-icon { font-size: 44rpx; }
.ach-name { font-size: 22rpx; color: #3D3529; margin-top: 10rpx; font-weight: 500; letter-spacing: 1rpx; }
.ach-desc { font-size: 18rpx; color: #9A9080; margin-top: 4rpx; text-align: center; white-space: nowrap; }

/* 设置 */
.settings-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(107,155,125,0.1);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
}
.setting-label { font-size: 28rpx; color: #3D3529; }
.setting-danger { color: #c0392b; }
.setting-arrow { font-size: 36rpx; color: #9A9080; }
.setting-line { height: 1rpx; background: #F0ECE4; margin: 0 28rpx; }
