/* 全局样式 - 春日清新风 */
page {
  background-color: #F7F4EE;
  color: #3D3529;
  font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  --color-primary: #6B9B7D;
  --color-primary-light: #8BB89D;
  --color-primary-dark: #4E7F62;
  --color-bg: #F7F4EE;
  --color-bg-card: #FFFFFF;
  --color-bg-elevated: #EDE9E1;
  --color-text: #3D3529;
  --color-text-secondary: #7A7060;
  --color-text-muted: #B0A898;
  --color-border: #E4DFD6;
}

/* 通用容器 */
.container {
  min-height: 100vh;
  background-color: var(--color-bg);
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 卡片 */
.card {
  background: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 32rpx;
  border: 1rpx solid var(--color-border);
  box-shadow: 0 2rpx 16rpx rgba(61, 53, 41, 0.06);
}

/* 主按钮 */
.btn-primary {
  background: linear-gradient(135deg, #6B9B7D 0%, #4E7F62 100%);
  color: rgba(255,255,255,0.95);
  border-radius: 100rpx;
  font-size: 30rpx;
  font-weight: 400;
  letter-spacing: 6rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(107, 155, 125, 0.35);
}

.btn-primary::after {
  border: none;
}

/* 次级按钮 */
.btn-ghost {
  background: transparent;
  color: var(--color-primary);
  border-radius: 100rpx;
  font-size: 26rpx;
  border: 1rpx solid rgba(107, 155, 125, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-ghost::after {
  border: none;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 28rpx 0;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
  font-size: 20rpx;
  background: var(--color-bg-elevated);
  color: var(--color-text-secondary);
  border: 1rpx solid var(--color-border);
}

.tag-primary {
  background: rgba(107, 155, 125, 0.1);
  color: var(--color-primary);
  border-color: rgba(107, 155, 125, 0.25);
}
