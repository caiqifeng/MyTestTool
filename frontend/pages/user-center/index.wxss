/* 用户中心页面样式 - 优化版 */
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F8F8F8 0%, #FFFFFF 100%);
}

.user-center-page {
  padding-bottom: 80rpx;
}

.user-header {
  background: linear-gradient(135deg, #FF6B35 0%, #FF9B70 100%);
  padding: 80rpx 32rpx 48rpx;
  color: #FFFFFF;
  position: relative;
  overflow: hidden;
}

.user-header::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  opacity: 0.3;
}

.user-avatar-section {
  display: flex;
  align-items: center;
  margin-bottom: 48rpx;
  position: relative;
  z-index: 1;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4px solid rgba(255, 255, 255, 0.4);
  margin-right: 32rpx;
  background-color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.user-info .user-name {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.user-info .user-level {
  font-size: 28rpx;
  opacity: 0.95;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 999px;
  display: inline-block;
}

.user-stats {
  display: flex;
  justify-content: space-around;
  text-align: center;
  position: relative;
  z-index: 1;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 32rpx 0;
  backdrop-filter: blur(20rpx);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.user-stats .stat-item {
  flex: 1;
  position: relative;
}

.user-stats .stat-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1px;
  height: 40rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

.user-stats .stat-value {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.user-stats .stat-label {
  font-size: 28rpx;
  opacity: 0.95;
  font-weight: 500;
}

.order-section,
.menu-section {
  background-color: #FFFFFF;
  margin: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  border: 1px solid #F0F0F0;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.order-section:active,
.menu-section:active {
  background-color: #F9F9F9;
}

.section-header {
  padding: 40rpx 32rpx;
  border-bottom: 1px solid #F0F0F0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #FFFFFF;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background-color: #FF6B35;
  border-radius: 3rpx;
}

.section-more {
  font-size: 28rpx;
  color: #999999;
  font-weight: 500;
}

.order-menu {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 0;
  background-color: #FFFFFF;
}

.menu-section .menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40rpx;
  padding: 40rpx 32rpx;
  background-color: #FFFFFF;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  border-radius: 20rpx;
  transition: background-color 0.2s ease;
}

.menu-item:active {
  background-color: #F8F8F8;
}

.menu-item .menu-icon {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF9B70 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 20rpx;
  color: #FFFFFF;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 53, 0.3);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.menu-item:active .menu-icon {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.2);
}

.menu-item .menu-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  text-align: center;
  line-height: 1.3;
}

.logout-section {
  margin: 32rpx;
}

.logout-btn {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.08);
  border: 1px solid #FFE5E5;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.logout-btn:active {
  background-color: #FFF5F5;
}

.logout-btn .logout-text {
  color: #FF4D4F;
  font-weight: 600;
  font-size: 32rpx;
  letter-spacing: 1rpx;
}