/* 颜色变量 */
:root {
  --color-primary: #FF6B35;
  --color-primary-light: #FF9B70;
  --color-error: #FF4D4F;
  --color-white: #FFFFFF;
  --color-background: #F8F8F8;
  --color-border: #E0E0E0;
  --color-text-primary: #333333;
  --color-text-secondary: #666666;
  --color-text-tertiary: #999999;
}

/* 间距变量 */
:root {
  --spacing-xs: 4px;
  --spacing-sm: 8px;
  --spacing-md: 16px;
  --spacing-lg: 24px;
  --spacing-xl: 32px;
}

/* 圆角变量 */
:root {
  --border-radius-sm: 4px;
  --border-radius-md: 8px;
  --border-radius-lg: 12px;
  --border-radius-round: 999px;
  --border-radius-circle: 50%;
}

/* 字体大小 */
:root {
  --font-size-xs: 12px;
  --font-size-sm: 14px;
  --font-size-md: 16px;
  --font-size-lg: 18px;
  --font-size-xl: 20px;
  --font-size-xxl: 24px;
}

/* 阴影 */
:root {
  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.page-container {
  min-height: 100vh;
  background-color: #F8F8F8;
}

.home-page {
  padding-bottom: 64rpx;
}

.home-search-bar {
  padding: 32rpx;
  background-color: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.search-input {
  display: flex;
  align-items: center;
  background-color: #F8F8F8;
  border-radius: 999px;
  padding: 24rpx 32rpx;
  border: 1px solid #F0F0F0;
}

.search-icon {
  margin-right: 16rpx;
  color: #999999;
  font-size: 32rpx;
}

.search-input input {
  flex: 1;
  font-size: 32rpx;
  background: transparent;
  border: none;
  outline: none;
  color: #333333;
}

.search-input input::placeholder {
  color: #999999;
}

.home-banner {
  padding: 0 32rpx;
  margin-top: 16rpx;
}

.banner-swiper {
  height: 320rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.banner-image {
  width: 100%;
  height: 100%;
}

.category-nav {
  padding: 48rpx 32rpx 32rpx;
  margin-top: 8rpx;
}

.category-scroll {
  white-space: nowrap;
  padding-bottom: 8rpx;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 48rpx;
  padding: 8rpx;
}

.category-item:last-child {
  margin-right: 0;
}

.category-icon {
  width: 96rpx;
  height: 96rpx;
  background-color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1px solid #F0F0F0;
}

.category-name {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
  white-space: nowrap;
}

.recommended-section,
.hot-section {
  padding: 0 32rpx;
  margin-bottom: 48rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background-color: #FF6B35;
  border-radius: 3rpx;
}

.section-more {
  font-size: 28rpx;
  color: #999999;
  font-weight: 500;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.product-item {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  border: 1px solid #F0F0F0;
}

.product-item:active {
  background-color: #F9F9F9;
}

.product-image {
  width: 100%;
  height: 220rpx;
  background-color: #F8F8F8;
}

.product-info {
  padding: 24rpx;
}

.product-name {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.product-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF4D4F;
}

.product-original-price {
  font-size: 24rpx;
  color: #999999;
  text-decoration: line-through;
  margin-left: 12rpx;
}

.product-list .product-card {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1px solid #F0F0F0;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.product-list .product-card:last-child {
  margin-bottom: 0;
}

.product-list .product-card:active {
  background-color: #F9F9F9;
}

.product-card-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  margin-right: 32rpx;
  background-color: #F8F8F8;
  flex-shrink: 0;
}

.product-card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.product-card-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  line-height: 1.3;
}

.product-card-desc {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 32rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-height: 1.4;
}

.product-card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.product-card-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #FF4D4F;
}

.product-card-sales {
  font-size: 28rpx;
  color: #999999;
  font-weight: 500;
}