/* 购物车页面样式 - 优化版 */
.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.cart-page {
  display: flex;
  flex-direction: column;
  flex: 1;
  background-color: #F8F8F8;
}

.cart-header {
  padding: 32rpx;
  background-color: #FFFFFF;
  border-bottom: 1px solid #E0E0E0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cart-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
}

.cart-edit {
  font-size: 32rpx;
  color: #FF6B35;
}

.cart-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 32rpx;
  color: #CCCCCC;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 48rpx;
}

.empty-action {
  background-color: #FF6B35;
  border-radius: 999px;
  padding: 16rpx 64rpx;
}

.empty-action-text {
  color: #FFFFFF;
  font-weight: 500;
  font-size: 32rpx;
}

.cart-content {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 280rpx; /* 增加内边距以避免底部结算栏遮挡 */
}

.cart-items .cart-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background-color: #FFFFFF;
  margin-bottom: 1px;
  border-bottom: 1px solid #F0F0F0;
  transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  position: relative;
}

.cart-items .cart-item:active {
  background-color: #F9F9F9;
}

.cart-items .cart-item:last-child {
  margin-bottom: 0;
  border-bottom: none;
}

.item-select {
  margin-right: 32rpx;
}

.select-checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2px solid #E0E0E0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  background-color: #FFFFFF;
}

.select-checkbox.selected {
  border-color: #FF6B35;
  background-color: #FF6B35;
  color: #FFFFFF;
}

.item-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
  margin-right: 32rpx;
  background-color: #F8F8F8;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
}

.item-info {
  flex: 1;
}

.item-name {
  display: block;
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.item-specs {
  display: block;
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #FF4D4F;
}

.item-quantity {
  display: flex;
  align-items: center;
  border: 1px solid #E0E0E0;
  border-radius: 999px;
  overflow: hidden;
  background-color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.quantity-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #333333;
  background-color: #F8F8F8;
  transition: background-color 0.2s ease, transform 0.1s ease;
}

.quantity-btn:active {
  background-color: #F0F0F0;
  transform: scale(0.95);
}

.quantity-btn.disabled {
  color: #CCCCCC;
  background-color: #F8F8F8;
}

.quantity-btn.disabled:active {
  background-color: #F8F8F8;
  transform: none;
}

.quantity-value {
  width: 80rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
}

.item-delete {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 32rpx;
}

.delete-icon {
  font-size: 48rpx;
  color: #FF4D4F;
  font-weight: bold;
}

.cart-select-all {
  padding: 32rpx;
  background-color: #FFFFFF;
  border-top: 1px solid #E0E0E0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.select-all-checkbox {
  display: flex;
  align-items: center;
}

.select-all-text {
  margin-left: 16rpx;
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.select-all-delete .delete-text {
  font-size: 32rpx;
  color: #999999;
}

.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  border-top: 1px solid #E0E0E0;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.footer-left .total-price {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.total-label {
  font-size: 28rpx;
  color: #666666;
}

.total-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #FF4D4F;
  margin-left: 8rpx;
}

.coupon-text {
  font-size: 24rpx;
  color: #FF6B35;
}

.footer-right .settle-btn {
  background: linear-gradient(135deg, #FF6B35 0%, #FF9B70 100%);
  border-radius: 999px;
  padding: 20rpx 64rpx;
  min-width: 200rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.settle-btn:active {
  opacity: 0.9;
}

.settle-btn.disabled {
  background: #CCCCCC;
  opacity: 0.5;
  box-shadow: none;
}

.settle-btn.disabled:active {
  transform: none;
  box-shadow: none;
}

.settle-text {
  color: #FFFFFF;
  font-weight: 600;
  font-size: 32rpx;
  letter-spacing: 1rpx;
}